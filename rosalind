import sys

file = open(sys.argv[1])
dna_str = file.read() #You can also put the text from the file into the code as a variable

A = dna_str.count("A")
C = dna_str.count("C")
G = dna_str.count("G")
T = dna_str.count("T")

print(A, C, G, T)


# 3

with open("rosalind_dna.txt") as fichier:
    s = fichier.read().strip()

A = C = G = T = 0

for lettre in s:
    if lettre == "A":
        A += 1
    elif lettre == "C":
        C += 1
    elif lettre == "G":
        G += 1
    else:
        T += 1

print(A, C, G, T)


