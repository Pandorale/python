with open("rosalind_dna.txt") as fichier:
    s = fichier.read().strip()

compteur = {
    "A": 0,
    "C": 0,
    "G": 0,
    "T": 0
}

for lettre in s:
    compteur[lettre] += 1

print(compteur["A"], compteur["C"], compteur["G"], compteur["T"])



